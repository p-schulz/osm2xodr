prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: expat
Version: 2.8.2
Description: expat XML parser
URL: https://libexpat.github.io/
Libs: "-L${libdir}" -llibexpat
Libs.private: 
Cflags: "-I${includedir}"
Cflags.private: -DXML_STATIC

