{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (macOS Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "macos-debug"],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "CMake: Configure (macOS Release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "macos-release"],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Build (macOS Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "macos-debug"],
      "dependsOn": "CMake: Configure (macOS Debug)",
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Build (macOS Release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "macos-release"],
      "dependsOn": "CMake: Configure (macOS Release)",
      "problemMatcher": ["$gcc"],
      "group": "build"
    },
    {
      "label": "Run on tiny_intersection (Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/build/macos-debug/osm2xodr",
      "args": [
        "${workspaceFolder}/examples/tiny_intersection.osm",
        "${workspaceFolder}/build/macos-debug/tiny_intersection.xodr",
        "--report", "${workspaceFolder}/build/macos-debug/tiny_intersection_report.txt"
      ],
      "dependsOn": "Build (macOS Debug)",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run checkers on tiny_intersection (Debug)",
      "type": "shell",
      "command": "python3 test/check_junction_continuity.py build/macos-debug/tiny_intersection.xodr && python3 test/check_road_link_continuity.py build/macos-debug/tiny_intersection.xodr && python3 test/check_turn_lane_routing.py examples/tiny_intersection.osm build/macos-debug/tiny_intersection.xodr",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": "Run on tiny_intersection (Debug)",
      "problemMatcher": [],
      "group": "test"
    }
  ]
}
